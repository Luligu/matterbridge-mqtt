{
  "name": "matterbridge-mqtt-frontend",
  "version": "1.0.0",
  "description": "Frontend for the matterbridge-mqtt plugin",
  "author": "https://github.com/Luligu",
  "license": "Apache-2.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "typecheck": "tsgo --noEmit -p tsconfig.json",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "runMeBeforePublish": "npm run format && npm run lint && npm run build && npm run typecheck"
  },
  "dependencies": {
    "@emotion/react": "11.14.0",
    "@emotion/styled": "11.14.1",
    "@mui/icons-material": "9.1.1",
    "@mui/material": "9.1.1",
    "react": "19.2.7",
    "react-dom": "19.2.7"
  },
  "devDependencies": {
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@typescript/native-preview": "7.0.0-dev.20260611.2",
    "@vitejs/plugin-react": "6.0.2",
    "oxfmt": "0.54.0",
    "oxlint": "1.69.0",
    "oxlint-tsgolint": "0.23.0",
    "typescript": "6.0.3",
    "vite": "8.0.16"
  }
}
